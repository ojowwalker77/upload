# Google AI Studio key — https://aistudio.google.com/apikey
# Leave unset to run with the deterministic mock Gemini layer (--mock).
GEMINI_API_KEY=

# Only needed with --transcriber openai (Whisper API)
OPENAI_API_KEY=

# Optional overrides
# UPLOAD_WORLD_GEMINI_MODEL=gemini-2.5-flash
# UPLOAD_WORLD_EMBEDDING_MODEL=gemini-embedding-2
# UPLOAD_WORLD_EMBEDDING_DIM=768
# UPLOAD_WORLD_FFMPEG_BIN=ffmpeg
# UPLOAD_WORLD_WHISPER_BIN=whisper-cli
# UPLOAD_WORLD_WHISPER_MODEL=base            # tiny | base | small | medium | large-v3-turbo
# UPLOAD_WORLD_WHISPER_MODEL_PATH=           # absolute path to a ggml model (skips auto-download)
# UPLOAD_WORLD_OPENAI_TRANSCRIBE_MODEL=whisper-1
# UPLOAD_WORLD_OLLAMA_URL=http://127.0.0.1:11434
# UPLOAD_WORLD_OLLAMA_EMBED_MODEL=embeddinggemma
