{
  "name": "upload-world",
  "version": "0.1.0",
  "description": "Multimodal ingest pipeline: any file → Gemini description/transcript → embeddings → pluggable vector store",
  "type": "module",
  "license": "MIT",
  "bin": {
    "upload-world": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.93.0",
    "@effect/platform-node": "^0.107.0",
    "effect": "^3.21.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.2.0",
    "sqlite-vec": "^0.1.7-alpha.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@effect/vitest": "^0.27.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "oxlint": "^1.73.0",
    "tsx": "^4.20.0",
    "vitest": "^3.2.0"
  }
}
